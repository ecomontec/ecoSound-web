<div class="modal fade" id="modal-div" role="dialog" style="overflow:visible">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tag {{ tag.id }}
                    {% if hasTaskAssignment %}
                        <span class="badge badge-info ml-2" title="This tag is assigned to you as a task">
                            <i class="fas fa-tasks"></i> Task
                        </span>
                    {% endif %}
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times</span></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div id="tag-panel" class="col-12">
                        <form id="tagForm" data-disabled="{{ disableTagForm }}">
                            <input name="tag_id" type="hidden" value="{{ tag.id }}">
                            <input name="recording_id" type="hidden" value="{{ tag.recording }}">
                            <input class='js-species-id' data-type="edit" name='species_id' type='hidden' value="{{ tag.species }}">
                            <input id="old_call_distance" type="hidden" value="{{ tag.callDistance }}">
                            <input id="edit" type="hidden" value="{{ edit }}">
                            <div class="form-row align-items-center">
                                <div class="form-group col-6">
                                    <label class="col-form-label-sm" for="soundscape_component">Soundscape Component</label>
                                    <select id="soundscape_component" name="soundscape_component" class="custom-select custom-select-sm">
                                        {% for soundscape_component in soundscape_components %}
                                            <option value="{{ soundscape_component.soundscapeComponent }}" {{ soundscape_component.soundscapeComponent == tag.soundscapeComponent ? "selected" }}>{{ soundscape_component.soundscapeComponent }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="form-group col-6">
                                    <label class="col-form-label-sm" for="sound_id">Sound Type</label>
                                    <select id="sound_id" name="sound_id" data-live-search="true">
                                        {% for soundType in soundTypes %}
                                            {% if soundType.soundscapeComponent==tag.soundscapeComponent %}
                                                <option value="{{ soundType.sound_id }}">{{ soundType.sound_type }}</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="form-row align-items-center biophony">
                                <div class="form-group col-auto" style="flex-grow: 1;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <label class="col-form-label-sm mb-0" for="speciesName">Species</label>
                                        <a class="col-form-label-sm mb-0" href="#" target="_blank" id="xenoImages" style="font-size: 0.75rem;">Xeno-Canto</a>
                                    </div>
                                    <input id="speciesName"
                                           data-type="edit"
                                           class="form-control form-control-sm mb-1 js-species-autocomplete"
                                           type="text"
                                           size="30"
                                           value="{{ tag.speciesName }}"
                                    >
                                </div>
                                <div class="form-group col-auto mb-1">
                                    <div class="form-check form-control-sm pt-4" id="uncertain_check">
                                        <input class="form-check-input" id="uncertain" name="uncertain" type="checkbox" value="1" {{ tag.uncertain ? "checked" }}>
                                        <label class="form-check-label" for="uncertain">Uncertain</label>
                                    </div>
                                </div>
                            </div>

                            <div class="form-row align-items-center">
                                <div class="form-group col-6 mb-1">
                                    <label class="col-form-label-sm" for="min_time">Time (sec)</label>
                                    <div class="input-group input-group-sm">
                                        <input id="min_time" class="form-control form-control-sm" name="min_time" type="text" maxlength="100" value="{{ tag.minTime }}" style="max-width: 70px;">
                                        <div class="input-group-prepend input-group-append"><span class="input-group-text">-</span></div>
                                        <input id="max_time" class="form-control form-control-sm" name="max_time" type="text" maxlength="100" value="{{ tag.maxTime }}" style="max-width: 70px;">
                                    </div>
                                </div>
                                <div class="form-group col-6 mb-1">
                                    <label class="col-form-label-sm" for="min_freq">Frequency (Hz)</label>
                                    <div class="input-group input-group-sm">
                                        <input id="min_freq" class="form-control form-control-sm" name="min_freq" type="text" maxlength="100" value="{{ tag.minFrequency }}" style="max-width: 70px;">
                                        <div class="input-group-prepend input-group-append"><span class="input-group-text">-</span></div>
                                        <input id="max_freq" class="form-control form-control-sm" name="max_freq" type="text" maxlength="100" value="{{ tag.maxFrequency }}" style="max-width: 70px;">
                                    </div>
                                </div>
                            </div>

                            <div class="form-row align-items-center mt-2 biophony" id="distance_group">
                                <div class="form-group col-auto mb-1">
                                    <label class="col-form-label-sm" for="callDistance">Sound Distance </label>
                                    <div class="input-group input-group-sm">
                                        <input id="callDistance" class="form-control form-control-sm" name="sound_distance_m" type="number" value="{{ tag.callDistance }}" readonly style="max-width: 80px;">
                                        <div class="input-group-append">
                                            <button type="button" class="btn btn-outline-primary btn-sm estimate-distance-btn" id="est_{{ tag.id }}" title="Estimate call distance">
                                                <i class="fas fa-bullhorn"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-auto mb-1">
                                    <div class="form-check form-control-sm pt-4" id="dist_check">
                                        <input class="form-check-input" id='distanceNotEstimable' name="distance_not_estimable" type="checkbox" value="1" {{ tag.distanceNotEstimable ? "checked" }}>
                                        <label class="form-check-label" for="distanceNotEstimable">
                                            Not estimable
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group col-4 biophony" id="individuals_group">
                                    <label class="col-form-label-sm" for="individuals">Individuals </label>
                                    <input id="individuals" class="form-control form-control-sm" name="individuals" min="0" max="1000" type="number" value="{{ tag.numberIndividuals }}" required>
                                    <div class="invalid-feedback">
                                        Please introduce a valid individuals.
                                    </div>
                                </div>
                                <div class="form-group col-4 biophony">
                                    <label class="col-form-label-sm" for="type">Animal Sound Type</label>
                                    <select id="animal_sound_type" name="animal_sound_type" class="custom-select custom-select-sm">
                                        <option value="0"></option>
                                        {% for animalSoundType in animalSoundTypes %}
                                            <option value="{{ animalSoundType.soundTypeId }}" {{ tag.type == animalSoundType.soundTypeId ? "selected" }}>{{ animalSoundType.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="form-group col-4">
                                    <div class="form-check form-control-sm pt-4" id="reference">
                                        <input class="form-check-input" id="referenceCall" name="reference_call" type="checkbox" value="1" {{ tag.referenceCall ? "checked" }}>
                                        <label class="form-check-label" for="referenceCall">Reference</label>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="comments" class="sr-only">Comments</label>
                                <textarea id="comments" name="comments" class="form-control form-control-sm" placeholder="Insert your comments" maxlength="200" rows="1">{{ tag.comments }}</textarea>
                            </div>

                            <div class="form-group mb-1">
                                {% if edit %}
                                    <div class="text-muted" style="font-size: 0.7rem;">Creator: {{ tag.creatorType }}{% if tag.confidence %}, Confidence: {{ tag.confidence }}{% endif %}</div>
                                {% endif %}
                                {% if isUserLogged %}
                                    {% if reviewPanel !='' %}
                                        <div class="text-muted" style="font-size: 0.7rem;">By {{ tag.userName }}, {{ tag.creationDate }} (UTC)</div>
                                    {% else %}
                                        <div class="text-muted" style="font-size: 0.7rem;">By {{ tag.userName }}</div>
                                    {% endif %}
                                {% endif %}
                                <input type="hidden" id="exportTagUrlData" value="{{ tag.id }}">
                            </div>
                        </form>
                    </div>
                    {% if reviewPanel !='' %}
                    <div id="review-panel">
                        <h6 class="mb-2 pb-2 border-bottom">Reviews</h6>
                        {{ reviewPanel | raw }}
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="modal-footer" style="flex-wrap: wrap; gap: 0.25rem;">
                {% if edit %}
                    <button type="button" class="btn btn-outline-primary btn-sm" {{ displaySaveButton }} id="saveButton" disabled>
                        <i class="fas fa-save" aria-hidden="true"></i> Save
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm" {{ displayDeleteButton }} id="deleteButton" data-tag-id="{{ tag.id }}">
                        <i class="fas fa-trash-alt" aria-hidden="true"></i>
                    </button>
                    <a href="#" id="exportTagUrl" class="btn btn-outline-secondary btn-sm" title="Share tag URL">
                        <i class="fa fa-share-alt"></i>
                    </a>
                    <div class="btn-group btn-group-sm ml-auto">
                        <a class='btn btn-sm {{ previous==0?'btn-secondary':'btn-outline-primary' }}' id="btn-previous" title="Previous tag">
                            <i class="fas fa-arrow-left" aria-hidden="true"></i>
                        </a>
                        <a class='btn btn-sm {{ next==0?'btn-secondary':'btn-outline-primary' }}' id="btn-next" title="Next tag">
                            <i class="fas fa-arrow-right" aria-hidden="true"></i>
                        </a>
                    </div>
                {% else %}
                    <button type="button" class="btn btn-outline-primary btn-sm" {{ displaySaveButton }} id="saveButton">
                        <i class="fas fa-save" aria-hidden="true"></i> Save
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm" {{ displayDeleteButton }} id="deleteButton" data-tag-id="{{ tag.id }}">
                        <i class="fas fa-trash-alt" aria-hidden="true"></i>
                    </button>
                {% endif %}
            </div>
        </div>
    </div>
</div>
<script>
    var soundTypes ={{ soundTypes|json_encode|raw }};
    // Also store globally for sidebar access
    window.sidebarSoundTypes = soundTypes;
    if ($('#modalX').val() && $('#modalX').val()) {
        $("#modal-div").offset({
            left: $('#modalX').val(),
            top: $('#modalY').val(),
        })
    }
    $(document).ready(function () {
        {% if tag.soundId %}
        $("#soundscape_component").change()
        {% else %}
        var soundscape_component = $.cookie('soundscape_component');
        var sound_id = $.cookie('sound_id');
        $("#soundscape_component").val(soundscape_component).change()
        $("#sound_id").find("option[value=" + sound_id + "]").prop("selected", true);
        {% endif %}
        $('#sound_id').selectpicker('refresh');
        // Only affect buttons within the tag form, not all buttons on page
        $("#modal-div .btn, #tag-sidebar-content .btn").css("text-align", "left");
        $('#tag-panel').on('input', 'input, select', function () {
            $('#saveButton').removeAttr('disabled');
        });
        $('#sound_id').on('changed.bs.select', function () {
            $('#saveButton').removeAttr('disabled');
        });
        $('#reviewForm').on('click', 'button', function () {
            $('#saveButton').removeAttr('disabled');
        });
        // Save button is now always just "Save"
    });
    $("#modal-div").on('shown.bs.modal', function () {
        if ($("#animal_sound_type")[0].options.length == 1) {
            $("#animal_sound_type").attr('disabled', true)
        }
        $(this).find('#speciesName').focus();
    });
    $("#soundscape_component").on('change', function () {
        if ($("#soundscape_component").find("option:selected").text() == 'biophony') {
            $(".biophony").show()
            $("#reference").addClass('pt-4')
        } else {
            $(".biophony").hide()
            $("#reference").removeClass('pt-4')
        }
        {% if not tag.soundId %}
        if ($.cookie('cookieConsent') == 'accepted') {
            $.cookie('soundscape_component', $("#soundscape_component").val(), {path: '/', expires: 180, samesite: 'None'});
        }
        {% endif %}
        
        // Use soundTypes from global scope (modal) or window.sidebarSoundTypes (sidebar)
        var typesData = (typeof soundTypes !== 'undefined') ? soundTypes : 
                        (typeof window.sidebarSoundTypes !== 'undefined') ? window.sidebarSoundTypes : null;
        
        if (!typesData) {
            console.error('No sound types data available');
            return;
        }
        
        $('#sound_id').empty()
        for (var key in typesData) {
            // Check both property name variations (snake_case and camelCase)
            const componentValue = typesData[key]['soundscape_component'] || typesData[key]['soundscapeComponent'];
            const soundIdValue = typesData[key]['sound_id'] || typesData[key]['soundId'];
            const soundTypeName = typesData[key]['sound_type'] || typesData[key]['soundType'];
            
            // Skip entries with empty sound type names
            if (!soundTypeName || soundTypeName.trim() === '') {
                continue;
            }
            
            if (componentValue == $("#soundscape_component").find("option:selected").text()) {
                if (soundIdValue == '{{ tag.soundId }}') {
                    $('#sound_id').append("<option value='" + soundIdValue + "' selected>" + soundTypeName + "</option>");
                } else {
                    $('#sound_id').append("<option value='" + soundIdValue + "'>" + soundTypeName + "</option>");
                }
            }
        }
        
        // Only call selectpicker refresh if it exists (modal mode, not sidebar)
        if (typeof $.fn.selectpicker !== 'undefined' && $('#sound_id').hasClass('selectpicker')) {
            $('#sound_id').selectpicker('refresh');
        }
    })
    {% if not tag.soundId %}
    $("#sound_id").on('change', function () {
        if ($.cookie('cookieConsent') == 'accepted') {
            $.cookie('sound_id', $("#sound_id").val(), {path: '/', expires: 180, samesite: 'None'});
        }
    })
    {% endif %}
    $('#distanceNotEstimable').click(function () {
        if ($(this).is(':checked')) {
            $('#callDistance').val(null);
        } else {
            $('#callDistance').val($('#old_call_distance').val())
        }
    });
    
    // Function to restore collapse state
    function restoreTimeFreqCollapseState() {
        var timeFreqCollapseState = $.cookie('timeFreqCollapsed');
        var isCollapsed = timeFreqCollapseState === 'true';
        var $collapse = $('#timeFreqCollapse');
        var $toggle = $('#timeFreqToggle');
        
        if (isCollapsed) {
            $collapse.hide();
            $toggle.attr('aria-expanded', 'false');
            $toggle.find('i').removeClass('fa-chevron-down').addClass('fa-chevron-right');
        } else {
            $collapse.show();
            $toggle.attr('aria-expanded', 'true');
            $toggle.find('i').removeClass('fa-chevron-right').addClass('fa-chevron-down');
        }
    }
    
    // Restore state on initial load
    restoreTimeFreqCollapseState();
    
    // Restore state when modal is shown (for next/previous tag navigation)
    $("#modal-div").on('shown.bs.modal', function () {
        restoreTimeFreqCollapseState();
    });
    
    // Handle toggle click
    $('#timeFreqToggle').on('click', function (e) {
        e.preventDefault();
        var $collapse = $('#timeFreqCollapse');
        var $toggle = $(this);
        var isCurrentlyShown = $collapse.is(':visible');
        
        if (isCurrentlyShown) {
            $collapse.hide();
            $toggle.attr('aria-expanded', 'false');
            $toggle.find('i').removeClass('fa-chevron-down').addClass('fa-chevron-right');
            if ($.cookie('cookieConsent') == 'accepted') {
                $.cookie('timeFreqCollapsed', 'true', {path: '/', expires: 180, samesite: 'None'});
            }
        } else {
            $collapse.show();
            $toggle.attr('aria-expanded', 'true');
            $toggle.find('i').removeClass('fa-chevron-right').addClass('fa-chevron-down');
            if ($.cookie('cookieConsent') == 'accepted') {
                $.cookie('timeFreqCollapsed', 'false', {path: '/', expires: 180, samesite: 'None'});
            }
        }
    });
    $("#modal-div").draggable({
        handle: ".modal-header",
        drag: function () {
            $('.modal-backdrop').remove();
        }
    });
    {% if next!=0 %}
    $('#btn-next').on('click', function (e) {
        // Store the navigation parameters in the form before submission
        $("#x").val('{{ next.minTime }}');
        $("#w").val('{{ next.maxTime }}');
        $("#y").val('{{ next.minFrequency }}');
        $("#h").val('{{ next.maxFrequency }}');
        $("#open").val('{{ next.id }}');
        $("#modalX").val($('#modal-div').offset().left);
        $("#modalY").val($('#modal-div').offset().top);
        // The type parameter is already in the form, just need to update the action
        // Note: filter and continuous_play states persist automatically via form submission
        $('#recordingForm').attr('action', "{{ baseUrl }}/recording/show/{{ next.recording }}");
        $("#recordingForm").submit();
        e.preventDefault();
    })
    {% endif %}
    {% if previous!=0 %}
    $('#btn-previous').on('click', function (e) {
        // Store the navigation parameters in the form before submission
        $("#x").val('{{ previous.minTime }}');
        $("#w").val('{{ previous.maxTime }}');
        $("#y").val('{{ previous.minFrequency }}');
        $("#h").val('{{ previous.maxFrequency }}');
        $("#open").val('{{ previous.id }}');
        $("#modalX").val($('#modal-div').offset().left);
        $("#modalY").val($('#modal-div').offset().top);
        // The type parameter is already in the form, just need to update the action
        // Note: filter and continuous_play states persist automatically via form submission
        $('#recordingForm').attr('action', "{{ baseUrl }}/recording/show/{{ previous.recording }}");
        $("#recordingForm").submit();
        e.preventDefault();
    })
    {% endif %}
</script>