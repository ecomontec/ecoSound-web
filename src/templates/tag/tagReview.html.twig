<form id="reviewForm" data-disabled="{{ disableReviewForm }}" data-user-id="{{ userLoggedId }}" data-user-name="{{ username }}" data-is-admin="{{ isAdmin ? '1' : '0' }}" data-is-user-logged="{{ isUserLogged ? '1' : '0' }}">
    {% if isReviewGranted %}
        <div class="row">
            <div class="col-12">
                <div class="form-group form-inline float-right mb-2">
                    <button type="button" class="btn btn-outline-primary btn-sm mr-2" id="review-accept-btn">Accept</button>
                    <button type="button" class="btn btn-outline-warning btn-sm mr-2" id="review-correct-btn">Revise</button>
                    <button type="button" class="btn btn-outline-danger btn-sm mr-2" id="review-delete-btn">Reject</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="review-uncertain-btn">Uncertain</button>
                </div>
            </div>
        </div>
        <input class="js-species-id" data-type="review" name="species_id" type="hidden">
        <input name="tag_id" type="hidden" value="{{ tagId }}">
        <input id="review_status" name="tag_review_status_id" type="hidden" value="">
        <input id="state" type="hidden">

        <div class="form-group" id="review_animal_group">
            <label for="reviewSpeciesName" class="col-form-label-sm">New Review Species</label>
            <input id="reviewSpeciesName" data-type="review" class="form-control form-control-sm js-species-autocomplete" type="text" disabled>
            <div class="invalid-feedback">
                Please select a species from the list.
            </div>
        </div>
        <div class="form-group">
            <label for="comments" class="sr-only">Comments</label>
            <textarea id="comments" name="note" class="form-control form-control-sm" placeholder="Insert your comments" maxlength="200" rows="2"></textarea>
        </div>
    {% endif %}
    <div class="review-table" style="max-height: 100px; overflow-y: auto;">
        <table class="table table-sm table-borderless mb-0" style="font-size: 0.75rem;">
            {% if reviews|length > 0 %}
            <thead>
            <tr>
                {% if isUserLogged %}
                    <th scope="col" class="py-1">Reviewer</th>
                {% endif %}
                <th scope="col" class="py-1">Status</th>
                <th scope="col" class="py-1">Species</th>
                <th scope="col" class="py-1">Date</th>
                {% if isUserLogged %}
                    <th scope="col" class="py-1" style="width: 30px;"></th>
                {% endif %}
            </tr>
            </thead>
            {% endif %}
            <tbody>
            {% for review in reviews %}
                <tr data-tag-id="{{ review.tag_id }}" data-reviewer-id="{{ review.reviewer_id }}">
                    {% if isUserLogged %}
                        <td class="py-1">{{ review.reviewer }}</td>
                    {% endif %}
                    <td class="py-1">{{ review.status }}</td>
                    <td class="py-1">{{ review.binomial }}</td>
                    <td class="py-1">{{ review.creation_date|date("d/m/Y") }}</td>
                    {% if isUserLogged and (review.reviewer_id == userLoggedId or isAdmin) %}
                        <td class="py-1">
                            <button type="button" class="btn btn-link btn-sm p-0 text-danger delete-review-btn" 
                                    data-tag-id="{{ review.tag_id }}" 
                                    data-user-id="{{ review.user_id }}"
                                    title="Delete review">
                                <i class="fas fa-times"></i>
                            </button>
                        </td>
                    {% elseif isUserLogged %}
                        <td class="py-1"></td>
                    {% endif %}
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</form>
