{% for key,tag in tags %}
    <div class="tag-controls {{ tag.style }}" id="{{ tag.id }}" data-tag-id="{{ tag.id }}" data-edit-url="{{ baseUrl }}/api/tag/edit/{{ tag.id }}{{ type?'?type='~type:'' }}" style="z-index: {{ tag.position }}; border-color: {{ tag.color }}; left: {{ tag.left }}px; top: {{ tag.top }}px; height: {{ tag.height }}px; width: {{ tag.width }}px; {{ show_tags ? '' : 'display:none;' }}"></div>
    <div class="card js-panel-tag" style="display:none;">
        <div class="card-header py-1 px-2">
            <small>{{ tag.id }} | {{ tag.title?tag.title:tag.soundType?tag.soundType:tag.soundscapeComponent }}</small>
        </div>
        <div class="card-body p-2 mx-auto">
            <a href='#' onclick='return false;' class='btn btn-outline-primary btn-sm zoom-tag' title='Zoom tag (+Alt: open in new tab)'>
                <i class='fas fa-search' aria-hidden='true'></i> Zoom
            </a>
            <div class="text-muted small mt-1 text-center">Click tag to edit</div>
        </div>
    </div>
{% endfor %}
