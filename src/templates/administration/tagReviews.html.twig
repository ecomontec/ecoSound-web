{% extends 'administration/admin.html.twig' %}

{% block admin_content %}
    <form id="reviewsForm" style="display:none">
        <input type="file" name="reviewsFile" id="reviewsFile" accept=".csv"/>
    </form>

    <div class="card mb-3" id="tagsList">
        <div class="card-header border-light bg-white text-right">
            <div class="form-inline">
                <form id="collectionForm" class="form-inline col-8" action="{{ baseUrl }}/admin/tagReviews">
                    <label for="projectId">Project</label>
                    <select id="projectId" name="projectId" class="form-control form-control-sm selectpicker ml-3" data-live-search="true">
                        {% for project in projects %}
                            <option value="{{ project.id }}" {{ project.id == projectId ? 'selected' }} {{ project.collection is null ?"disabled" }}>
                                {{ project.name }}{{ project.collection_id }}{{ project.collection is null ?" (No Data)" }}
                            </option>
                        {% endfor %}
                    </select>
                    <label for="collId" class="ml-3">Collection</label>
                    <select id="colId" name="colId" class="form-control form-control-sm selectpicker ml-3" data-live-search="true">
                        {% for collection in collections %}
                            <option value="{{ collection.id }}" {{ collection.id == colId ? 'selected' }}>
                                {{ collection.name }}
                            </option>
                        {% endfor %}
                    </select>
                    <label for="recordingId" class="ml-3">Recording</label>
                    <select id="recordingId" name="recordingId" class="form-control form-control-sm selectpicker ml-3" data-live-search="true">
                        <option></option>
                        {% for recording in recordings %}
                            <option value="{{ recording.recording_id }}" {{ recording.recording_id == recordingId ? 'selected' }}>
                                {{ recording.name }}
                            </option>
                        {% endfor %}
                    </select>
                </form>
                <div class="col-4 form-inline justify-content-end">
                    <label class="mr-2">Search:</label>
                    <input class="form-control-sm" id="search">
                </div>
            </div>
            <button id="viewing" name="table-btn" class="btn btn-outline-primary btn-sm mt-2" type="button" data-target="#viewing" disabled>
                <i class="fas fa-eye"></i>
                View
            </button>
            <button id="deletion" name="table-btn" class="btn btn-outline-primary btn-sm mt-2" type="button" data-target="#deletion" disabled>
                <i class="fas fa-trash"></i>
                Delete
            </button>
            <button id="tagReviewsExport" class="btn btn-outline-primary btn-sm mt-2" type="button" data-target="#tagReviewsExport" aria-expanded="false" aria-controls="tagReviewsExport">
                <i class="fa fa-file-csv"></i>
                Save all as CSV
            </button>
            <div class="btn-group ml-2 mt-2">
                <button type="button" class="btn btn-outline-primary btn-sm dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="fa fa-upload"></i> Upload / Instructions
                </button>
                <div class="dropdown-menu">
                    <a id="reviewsButton" class="dropdown-item" href="#">Upload Reviews</a>
                    <a id="viewReviewsInstructions" class="dropdown-item" href="#">Reviews Instructions</a>
                    <div class="dropdown-divider"></div>
                    <a id="reviewsDemo" class="dropdown-item" href="#">Download Template</a>
                    <a id="exportSpecies" class="dropdown-item" href="#">Export Species</a>
                </div>
            </div>
        </div>
        <table id="tagReviewsTable" style="display:none;white-space: nowrap;">
            <thead class="table-borderless">
            <tr style="font-size: .875rem;">
                <th>
                    <input type="checkbox" class="js-all-checkbox" name="check-all" id="check-all">
                </th>
                <th>#</th>
                <th>Recording</th>
                <th>Reviewer</th>
                <th>Status</th>
                <th>Species</th>
                <th>Note</th>
                <th style="width: 120px">Creation Date (UTC)</th>
            </tr>
            </thead>
            <tbody class="form-control-sm js-review-list"></tbody>
        </table>
    </div>
    <div class="modal fade" id="modal-div" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Warning</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body ml-3">
                    <div>
                        <div class="form-group">
                            <input id="delete_id" type="hidden">
                            <label id="delete_info"></label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button id="js-close-button" type="button" class="btn btn-outline-secondary" data-dismiss="modal" aria-label="Close">
                        <i class="fas fa-times"></i>
                        Close
                    </button>
                    <button id="js-delete-button" type="button" class="btn btn-outline-danger">
                        <i class="fas fa-trash-alt"></i>
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-reviews-info" tabindex="-1" role="dialog" aria-labelledby="modal-reviews-info-label" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modal-reviews-info-label">Reviews CSV Upload Instructions</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Upload a CSV file with the following columns:</p>
                    <h6>Required Columns:</h6>
                    <ul>
                        <li><strong>tag_id</strong>: Tag ID (must exist in database)</li>
                        <li><strong>tag_review_status_id</strong>: Status ID: 1=accepted, 2=corrected, 3=rejected, 4=uncertain</li>
                    </ul>
                    <h6>Optional Columns:</h6>
                    <ul>
                        <li><strong>species_id</strong>: Species ID (must exist if provided, required for corrected status)</li>
                        <li><strong>note</strong>: Review notes/comments</li>
                    </ul>
                    <p class="mt-3"><strong>Download files:</strong></p>
                    <ul>
                        <li><a href="#" id="reviewsDemo2">Download Reviews Template</a></li>
                        <li><a href="#" id="exportSpecies2">Export Species Reference Table</a></li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block header %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            $('#tagReviewsTable').show()
            let table = $('#tagReviewsTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": '{{ baseUrl }}/admin/tagReviewMgr/getListByPage/{{ colId|default(0) }}/{{ recordingId|default(0) }}',
                    "type": 'POST',
                    "error": function (xhr, error, thrown) {
                        console.error('DataTable error:', xhr.status, error, thrown);
                        if (xhr.responseText) {
                            console.error('Response:', xhr.responseText);
                        }
                        if (xhr.status == 400 || xhr.status == 404 || xhr.status == 500) {
                            // Don't reload automatically, just log the error
                            alert('Error loading reviews. Please check console for details.');
                        }
                    }
                },
                "dom": 'lrtip',
                "stateSave": true,
                "StateDuration": -1,
                "order": [[1, 'asc']],
                "columnDefs": [
                    {
                        "orderable": false,
                        "targets": [0]
                    },
                    {
                        "className": "dt-center",
                        "targets": [0],
                    },
                ],
                "bAutoWidth": false,
                "scrollX": true,
            });
            if (table.state.loaded()) {
                $('#search').val(table.state.loaded().search.search);
            }
            $('#search').on('input', () => {
                table.search($('#search').val()).draw();
            });
        });

        document.addEventListener("DOMContentLoaded", function () {
            'use strict';
            $(document).on('click', '#tagReviewsExport', function () {
                window.location.href = '{{ baseUrl }}/api/admin/tagReviewMgr/export/{{ colId }}';
            });

            // Reviews CSV Upload
            $('#reviewsButton').click(function(e) {
                e.preventDefault();
                $('#reviewsFile').click();
            });

            $('#reviewsFile').on('change', function() {
                var file = this.files[0];
                if (!file) return;

                var fileName = file.name;
                var fileSize = file.size;
                var fileType = file.type;

                if (fileType !== 'text/csv' && !fileName.endsWith('.csv')) {
                    alert('Please select a CSV file.');
                    $('#reviewsForm')[0].reset();
                    return;
                }

                if (fileSize > 5242880) {
                    alert('File size exceeds 5MB limit.');
                    $('#reviewsForm')[0].reset();
                    return;
                }

                var formData = new FormData();
                formData.append('file', file);

                $.ajax({
                    url: '{{ baseUrl }}/api/file/reviews',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.message === 'Upload success.') {
                            location.reload();
                        } else {
                            alert(response.message || 'Upload completed');
                            $('#reviewsForm')[0].reset();
                        }
                    },
                    error: function(xhr) {
                        var errorMsg = 'Upload failed.';
                        try {
                            var response = JSON.parse(xhr.responseText);
                            errorMsg = response.message || errorMsg;
                        } catch(e) {}
                        alert(errorMsg);
                        $('#reviewsForm')[0].reset();
                    }
                });
            });

            // Template and export downloads
            $('#reviewsDemo, #reviewsDemo2').click(function(e) {
                e.preventDefault();
                window.location.href = '{{ baseUrl }}/admin/tagReviews/downloadTemplate';
            });

            $('#exportSpecies, #exportSpecies2').click(function(e) {
                e.preventDefault();
                window.location.href = '{{ baseUrl }}/admin/tagReviews/exportSpecies';
            });

            $('#viewReviewsInstructions').click(function(e) {
                e.preventDefault();
                $('#modal-reviews-info').modal('show');
            });

            $('#js-delete-button').click(function (e) {
                let id = [];
                $('.js-checkbox:checked').each(function () {
                    id.push($(this).data('id'));
                });
                let data = {'id': id};
                postRequest('{{ baseUrl }}/api/tagReview/delete', data, false, false, function () {
                    location.reload();
                });
            });
            $('#tagReviewsTable tbody').on('change', 'select[name=tag_review_status_id]', function () {
                let id = $(this).closest('tr').find('.js-checkbox').data('id')
                if ($('option:selected', this).text() == 'Corrected') {
                    $('#speciesName_' + id).show()
                } else if ($('option:selected', this).text() == 'Accepted') {
                    $('#speciesName_' + id).hide()
                    $('.js-species-id' + id).val($('#tag_species' + id).val())
                } else {
                    $('#speciesName_' + id).hide()
                    $('#js-species-id' + id).val('')
                }
            });
            $(".js-review-list").on('change', 'input, select, textarea', function () {
                if ($(this)[0].className == 'js-checkbox') {
                    return
                }
                saveFormList($(this), 'api/tagReview/save');
            });
            $('#projectId').change(function () {
                $('#colId').val("")
                $('#recordingId').val("")
                $("#collectionForm").submit();
            });
            $('#colId').change(function () {
                $('#recordingId').val("")
                $("#collectionForm").submit();
            });
            $('#recordingId').change(function () {
                $("#collectionForm").submit();
            });
            $('button[name="table-btn"][data-target="#viewing"]').click(function (e) {
                $('.js-checkbox:checked').each(function () {
                    window.open('{{ baseUrl }}/recording/show/' + $(this).data('recording-id') + '?t_min=' + $(this).data('tmin') + '&t_max=' + $(this).data('tmax') + '&f_min=' + $(this).data('fmin') + '&f_max=' + $(this).data('fmax'), '_blank');
                });
                e.preventDefault();
            })
            $('button[name="table-btn"][data-target="#deletion"]').click(function (e) {
                if ($('.js-checkbox:checked').length > 1) {
                    $('#delete_info').html("Are you sure you want to delete these <b class=\"text-danger\" >" + $('.js-checkbox:checked').length + "</b> entries?")
                } else {
                    $('#delete_info').html("Are you sure you want to delete this entry?")
                }
                $("#modal-div").modal('show');
            })

        });
    </script>
{% endblock %}
