{% extends 'base.html.twig' %}

{% block body %}
    <style>
        .col-4, .col-8, .col-12 {
            padding-right: 0;
            padding-left: 0;
        }
    </style>
    <div class="container">
        <nav aria-label="breadcrumb">
            <ul class="breadcrumb bg-white mt-4">
                <li class="breadcrumb-item" aria-current="page">
                    <a href="{{ baseUrl }}/admin/settings">Dashboard</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ section }}</li>
            </ul>
        </nav>

        <div class="row">
            <div class="col-lg-2">
                <ul class="nav flex-column nav-pills">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ baseUrl }}/admin/settings">
                            <i class="fas fa-cog pr-1"></i>
                            Settings</a>
                    </li>
                    {% if isManage %}
                        {% if is_project_manage %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/users">
                                    <i class="fas fa-user pr-1"></i>
                                    Users</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/selfService">
                                    <i class="fas fa-user pr-1"></i>
                                    User</a>
                            </li>
                        {% endif %}
                        {% if is_admin %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/projects">
                                    <i class="fas fa-desktop pr-1"></i>
                                    Projects</a>
                            </li>
                        {% endif %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ baseUrl }}/admin/collections">
                                <i class="fas fa-music pr-1"></i>
                                Collections</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ baseUrl }}/admin/recordings">
                                <i class="fas fa-compact-disc pr-1"></i>
                                Recordings</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ baseUrl }}/admin/sites">
                                <i class="fa fa-sites pr-1"></i>
                                Sites</a>
                        </li>
                        {% if is_admin %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/species">
                                    <i class="fas fa-bullseye pr-1"></i>
                                    Species</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/recorders">
                                    <i class="fas fa-hdd pr-1"></i>
                                    Recorders</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/microphones">
                                    <i class="fas fa-microphone pr-1"></i>
                                    Microphones</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ baseUrl }}/admin/sounds">
                                    <i class="fas fa-book pr-1"></i>
                                    Sounds</a>
                            </li>
                        {% endif %}
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ baseUrl }}/admin/selfService">
                                <i class="fas fa-user pr-1"></i>
                                User</a>
                        </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ baseUrl }}/admin/tags">
                            <i class="fa fa-tag pr-1"></i>
                            Tags</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ baseUrl }}/admin/tagReviews">
                            <i class="fa fa-tags pr-1"></i>
                            Reviews</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ baseUrl }}/admin/tasks">
                            <i class="fa-solid fa-user-tag pr-1"></i>
                            Tasks</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ baseUrl }}/admin/indexLogs">
                            <i class="fa fa-info-circle pr-1"></i>
                            Index Logs</a>
                    </li>
                    {% if isManage %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ baseUrl }}/admin/queues">
                                <i class="fa-solid fa-list-ol pr-1"></i>
                                Queue</a>
                        </li>
                    {% endif %}
                </ul>
            </div>

            <div class="col-lg-10">
                {% block admin_content %}{% endblock %}
            </div>
        </div>
    </div>
    <script>
        $(document).ready(function () {
            let currentPath = window.location.pathname;
            $('.nav-link').each(function () {
                let linkHref = $(this).attr('href');
                if (linkHref) {
                    var linkLastField = linkHref.split('/').filter(function (el) {
                        return el !== '';
                    }).pop();
                    if (currentPath.indexOf(linkLastField) !== -1) {
                        $(this).addClass('txt-primary')
                    }
                }
            });

            // Admin filter persistence with localStorage
            var adminPage = window.location.pathname.split('/').filter(el => el !== '').pop();
            var storagePrefix = 'biosounds_admin_filter_';
            
            // Restore filter values from localStorage on page load
            function restoreFilters() {
                var savedProjectId = localStorage.getItem(storagePrefix + 'projectId');
                var savedColId = localStorage.getItem(storagePrefix + 'colId');
                var savedRecordingId = localStorage.getItem(storagePrefix + 'recordingId');
                
                var needsReload = false;
                var formToSubmit = null;
                
                // Check project dropdown
                if (savedProjectId && $('#projectId').length) {
                    var currentProjectId = $('#projectId').val();
                    if (currentProjectId != savedProjectId) {
                        $('#projectId').val(savedProjectId);
                        $('#projectId').selectpicker('refresh');
                        needsReload = true;
                        formToSubmit = $('#projectId').closest('form');
                    }
                }
                
                // Check collection dropdown
                if (savedColId && $('#colId').length) {
                    var currentColId = $('#colId').val();
                    if (currentColId != savedColId && $('#colId option[value="' + savedColId + '"]').length > 0) {
                        $('#colId').val(savedColId);
                        $('#colId').selectpicker('refresh');
                        needsReload = true;
                        formToSubmit = $('#colId').closest('form');
                    }
                }
                
                // Check recording dropdown
                if (savedRecordingId && $('#recordingId').length) {
                    var currentRecordingId = $('#recordingId').val();
                    if (currentRecordingId != savedRecordingId && $('#recordingId option[value="' + savedRecordingId + '"]').length > 0) {
                        $('#recordingId').val(savedRecordingId);
                        $('#recordingId').selectpicker('refresh');
                        needsReload = true;
                        formToSubmit = $('#recordingId').closest('form');
                    }
                }
                
                // Submit form to reload page with correct filters
                if (needsReload && formToSubmit) {
                    formToSubmit.submit();
                }
            }
            
            // Save filter value to localStorage
            function saveFilter(filterId, value) {
                if(value) {
                    localStorage.setItem(storagePrefix + filterId, value);
                } else {
                    localStorage.removeItem(storagePrefix + filterId);
                }
            }
            
            // Restore filters after a small delay to ensure selectpicker is initialized
            setTimeout(restoreFilters, 100);
            
            // Save filter values when dropdowns change
            $(document).on('change', '#projectId', function() {
                saveFilter('projectId', $(this).val());
                // Clear dependent filters
                localStorage.removeItem(storagePrefix + 'colId');
                localStorage.removeItem(storagePrefix + 'recordingId');
            });
            
            $(document).on('change', '#colId', function() {
                saveFilter('colId', $(this).val());
                // Clear dependent recording filter
                localStorage.removeItem(storagePrefix + 'recordingId');
            });
            
            $(document).on('change', '#recordingId', function() {
                saveFilter('recordingId', $(this).val());
            });
        });
    </script>
{% endblock %}
